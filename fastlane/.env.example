# Copia este archivo a la raíz del repo como `.env` o a `fastlane/.env`
# (los archivos `.env` están en .gitignore — nunca subas la clave .p8).
#
# App Store Connect → Users and Access → Integrations → App Store Connect API → Generar clave
# Descargas un .p8 (solo una vez). Anota Key ID e Issuer ID en la misma pantalla.

APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=12345678-1234-1234-1234-123456789012

# No uses APP_STORE_CONNECT_API_KEY salvo que sea JSON oficial (key_id, issuer_id, key en base64).
#
# IMPORTANTE: En Fastlane, APP_STORE_CONNECT_API_KEY_PATH (y PILOT_API_KEY_PATH) son para un
# fichero JSON de API Key, NO para el AuthKey.p8 de Apple. Usa APP_STORE_CONNECT_P8_PATH para el .p8.
# (El Fastfile borra las variables “PATH” de Fastlane tras leer el .p8 por compatibilidad con .env viejos.)

# Ruta al AuthKey_XXX.p8 (PEM de Apple):
APP_STORE_CONNECT_P8_PATH=/ruta/absoluta/a/AuthKey_XXXXXXXXXX.p8

# Alternativas sin fichero en disco:
# APP_STORE_CONNECT_API_KEY_CONTENT_BASE64=<una sola línea: base64 < AuthKey_XXX.p8 | tr -d '\n'>
# APP_STORE_CONNECT_API_KEY_CONTENT=-----BEGIN PRIVATE KEY-----...

# Opcional: si tu Appfile no coincide con el team del .p8
# FASTLANE_TEAM_ID=8AJBS923B3

# Opcional — típico en pipelines para menos ruido / comprobación de versión:
# FASTLANE_SKIP_UPDATE_CHECK=1
